parse_subcommands() {
    local subcmd="$1"
    shift
    case "$subcmd" in
        add) tmpl::add "$@" ;;
        remove) tmpl::remove "$@" ;;
        *)
            die e "Unknown subcommand or option"
            exit 1
            ;;
    esac
}

main() {
    local opt OPTIND OPTARG
    while getopts hp:w:x: opt "$@"; do
        case "$opt" in
            h)
                help
                exit
                ;;
            p)
                prefix="$OPTARG"
                ;;
            w)
                SYSTEMS+=("win") TARGETPREFIX[win]="$OPTARG"
                ;;
            x)
                SYSTEMS+=("nix") TARGETPREFIX[nix]="$OPTARG"
                ;;
            ?)
                die e 'add: Unknown option.'
                usage >&2
                exit 1
                ;;
        esac
    done
    shift $((OPTIND - 1))
    parse_subcommands "$@"
}

# Entry point
main "$@"
